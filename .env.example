PROXMOX_HOST=192.168.1.10
PROXMOX_PORT=8006
PROXMOX_USER=root@pam
PROXMOX_PASSWORD=yourpassword
# PROXMOX_KEY_PATH=~/.ssh/id_rsa  # alternative to password, or set DEVBOX_KEY_PATH as fallback
PROXMOX_NODE=homelab
PROXMOX_GATEWAY=192.168.1.1
PROXMOX_CT_TEMPLATE=local:vztmpl/debian-12-standard_12.7-1_amd64.tar.zst
PROXMOX_CT_STORAGE=local-lvm
PROXMOX_CT_BRIDGE=vmbr0
# PROXMOX_TLS_VERIFY=true  # enable TLS cert validation (disabled by default — Proxmox uses self-signed certs)

DEVBOX_HOST=192.168.1.14
DEVBOX_PORT=22
DEVBOX_USER=root
DEVBOX_PASSWORD=yourpassword
# OR use key auth (comment out DEVBOX_PASSWORD and uncomment below):
# DEVBOX_KEY_PATH=~/.ssh/id_rsa
# SSH_STRICT_HOST_KEY=true  # enable known_hosts verification (disabled by default — homelab host keys change frequently)

# Base path where docker-compose projects live on the devbox
DEVBOX_PROJECTS_DIR=/opt/projects

# ── QNAP NAS — SSH access ──────────────────────────────────────────────────────
QNAP_HOST=192.168.1.20
QNAP_PORT=22
QNAP_USER=admin
QNAP_PASSWORD=yourpassword
# QNAP_KEY_PATH=~/.ssh/id_rsa  # alternative to password
# QNAP_STORAGE_SHARES=/share/media /share/backups /share/vmstore
# QNAP_DRIVE_DEVICES=/dev/sda /dev/sdb

# ── Media services ─────────────────────────────────────────────────────────────
RADARR_URL=http://192.168.1.14:7878
RADARR_API_KEY=yourkey
RADARR_ROOT_FOLDER=/nas/movies

SONARR_URL=http://192.168.1.14:8989
SONARR_API_KEY=yourkey
SONARR_ROOT_FOLDER=/nas/series

PLEX_URL=http://192.168.1.14:32400
PLEX_TOKEN=yourtoken

PROWLARR_URL=http://192.168.1.14:9696
PROWLARR_API_KEY=yourkey

OVERSEERR_URL=http://192.168.1.14:5055
OVERSEERR_API_KEY=yourkey

SABNZBD_URL=http://192.168.1.14:8085
SABNZBD_API_KEY=yourkey

# ── Tautulli (Plex analytics) ─────────────────────────────────────────────────
TAUTULLI_URL=http://192.168.1.14:8181
TAUTULLI_API_KEY=yourkey

# ── Bazarr (subtitles) ────────────────────────────────────────────────────────
BAZARR_URL=http://192.168.1.14:6767
BAZARR_API_KEY=yourkey

# ── Lidarr (music) ────────────────────────────────────────────────────────────
LIDARR_URL=http://192.168.1.14:8686
LIDARR_API_KEY=yourkey
LIDARR_ROOT_FOLDER=/nas/music

# ── Readarr (books/audiobooks) ────────────────────────────────────────────────
READARR_URL=http://192.168.1.14:8787
READARR_API_KEY=yourkey
READARR_ROOT_FOLDER=/nas/books

# ── Monitoring ────────────────────────────────────────────────────────────────
PROMETHEUS_URL=http://192.168.1.14:9090

GRAFANA_URL=http://192.168.1.14:3000
GRAFANA_TOKEN=glsa_xxxxxxxxxxxxxxxxxxxx  # create via: Grafana → Admin → Service accounts

UPTIME_KUMA_URL=http://192.168.1.14:3001
UPTIME_KUMA_USER=admin
UPTIME_KUMA_PASSWORD=yourpassword

# ── AdGuard Home (DNS / ad blocking) ─────────────────────────────────────────
ADGUARD_URL=http://192.168.1.14:3000
ADGUARD_USER=admin
ADGUARD_PASSWORD=yourpassword

# ── Proxmox Backup Server ─────────────────────────────────────────────────────
PBS_URL=https://192.168.1.11:8007
PBS_TOKEN_ID=root@pam!mcp
PBS_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PBS_NODE=localhost
# PBS_TLS_VERIFY=true  # enable TLS cert validation (disabled by default — PBS uses self-signed certs)

# ── Notifications ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghikl-zyx57W2v1u123ew11
TELEGRAM_CHAT_ID=-1001234567890

# ── Media stack (optional) ────────────────────────────────────────────────────
# Comma-separated container names for media_logs / media_restart allowlisting.
# Defaults to: plex,radarr,sonarr,sabnzbd,seerr,prowlarr,flaresolverr
# MEDIA_CONTAINERS=plex,radarr,sonarr,sabnzbd,seerr,prowlarr

# LXC container ID of the media stack (used for GPU/security checks on Proxmox)
MEDIA_LXC_ID=102

# Disk paths shown in media_dashboard storage section (space-separated)
DASHBOARD_DISK_PATHS=/mnt/data

# ── Dashboard Python helper (optional overrides) ──────────────────────────────
# These are set on the devbox side, not in this .env. Documented here for reference.
# MEDIA_ENV_PATH=/opt/media/.env
# SABNZBD_CONFIG_PATH=/opt/media/config/sabnzbd/sabnzbd.ini
